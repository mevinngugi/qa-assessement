      "name": "2.1 — Public API Exploration",
      "item": [
        {
          "name": "Task A — Validate the BTC/ZAR market summary",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "//Status to be 200",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "//Response time to be less than 500ms",
                  "pm.test(\"Response time to be less than 500ms\", function() {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "",
                  "var response = pm.response.json();",
                  "",
                  "//currency pair to be the same as the currency pair in the request",
                  "pm.test(\"Currency Pair Match\", function () {",
                  "    pm.expect(response.currencyPair).to.eql(pm.environment.get(\"currencyPair\"));",
                  "});",
                  "",
                  "//ask price to be greater than bid price",
                  "pm.test(\"Ask Price Greater than Bid Price\", function () {",
                  "    pm.expect(response.askPrice > response.bidPrice).to.be.true",
                  "});",
                  "",
                  "//Expect response to have the following keys",
                  "pm.test(\"Response contains expected keys\", function () {",
                  "    pm.expect(response).to.have.all.keys(\"currencyPair\", \"askPrice\", \"bidPrice\", \"lastTradedPrice\", \"previousClosePrice\", \"baseVolume\", \"quoteVolume\", \"highPrice\", \"lowPrice\", \"created\", \"changeFromPrevious\", \"markPrice\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-VALR-API-KEY",
                "value": "",
                "type": "text"
              },
              {
                "key": "X-VALR-SIGNATURE",
                "value": "",
                "type": "text"
              },
              {
                "key": "X-VALR-TIMESTAMP",
                "value": "",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseURL}}/v1/public/{{currencyPair}}/marketsummary",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "v1",
                "public",
                "{{currencyPair}}",
                "marketsummary"
              ]
            }
          },
          "response": []
        },
