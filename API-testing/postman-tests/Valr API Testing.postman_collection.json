                  "",
                  "//Response time to be less than 500ms",
                  "pm.test(\"Response time to be less than 500ms\", function() {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "",
                  "//best bid is lower than best ask",
                  "//Ask orders are sorted by price ascending l-h",
                  "//Bid orders are sorted by price descending h-l",
                  "",
                  "var response = pm.response.json();",
                  "",
                  "",
                  "console.log(response.Bids.at(-1).price<response.Asks[0].price)",
                  "pm.test(\"The best bid is lower than best ask price\", function(){",
                  "    pm.expect(response.Bids.at(-1).price < response.Asks[0].price).to.be.true",
                  "})",
                  "",
                  "",
                  "",
                  "",
                  "//Has both Asks and Bids",
                  "//Each element in the list has side, quantity, price, currencyPair, orderCount",
                  "//side is either \"buy\" or \"sell\"",
                  "//price is greater than 0"
                ],
